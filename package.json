{
  "name": "xitto-kernel",
  "version": "0.9.27",
  "type": "module",
  "description": "領域無關的 agent 底座（kernel + 可插拔 DomainPack），從 xitto-code 抽象而來",
  "keywords": [
    "agent",
    "llm",
    "ai-agent",
    "agent-framework",
    "domain-pack",
    "sandbox",
    "seatbelt",
    "cli"
  ],
  "license": "MIT",
  "author": "ishoplus",
  "homepage": "https://github.com/ishoplus/xitto-kernel#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ishoplus/xitto-kernel.git"
  },
  "bugs": {
    "url": "https://github.com/ishoplus/xitto-kernel/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "xitto-kernel": "bin/xitto-kernel.js"
  },
  "files": [
    "src",
    "bin",
    "docs",
    "README.md",
    "README.zh-TW.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "demo": "node examples/demo.js",
    "eval": "node eval/run.js",
    "serve": "node src/app/server.js",
    "serve:local": "node scripts/serve-local.js",
    "start": "node bin/xitto-kernel.js",
    "i18n:hans": "node scripts/i18n-hans.mjs"
  },
  "exports": {
    ".": "./src/index.js",
    "./app": "./src/app/index.js",
    "./packs/coding": "./src/packs/coding/index.js",
    "./packs/data-query": "./src/packs/data-query/index.js",
    "./packs/notes": "./src/packs/notes/index.js",
    "./packs/general": "./src/packs/general/index.js",
    "./packs/deep-research": "./src/packs/deep-research/index.js",
    "./packs/devops": "./src/packs/devops/index.js",
    "./packs/patent": "./src/packs/patent/index.js",
    "./packs/uiux": "./src/packs/uiux/index.js",
    "./packs/docgen": "./src/packs/docgen/index.js"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.80.10",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cli-highlight": "^2.1.11",
    "docx": "^9.7.1",
    "ink": "^7.1.1",
    "jose": "^6.2.3",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "ink-testing-library": "^4.0.0",
    "opencc-js": "^1.4.1"
  },
  "optionalDependencies": {
    "mysql2": "^3.11.0",
    "pg": "^8.13.0"
  }
}
